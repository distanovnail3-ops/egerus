      function resizeCanvas() {
        const rect = canvas.getBoundingClientRect();
        dpr = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, Math.round(rect.width * dpr));
        canvas.height = Math.max(1, Math.round(rect.height * dpr));
        draw();
      }

      function pointFromEvent(event) {
        const rect = canvas.getBoundingClientRect();
        return {
          x: event.clientX - rect.left,
          y: event.clientY - rect.top,
          pressure: event.pressure && event.pressure > 0 ? event.pressure : 0.55
        };
      }

      function drawStroke(context, stroke, map = (point) => point) {
        if (!stroke.length) return;
        const first = map(stroke[0]);
        context.beginPath();
        context.moveTo(first.x, first.y);
        if (stroke.length === 1) {
          context.arc(first.x, first.y, 3, 0, Math.PI * 2);
          context.fill();
          return;
        }
        for (let i = 1; i < stroke.length; i += 1) {
          const p = map(stroke[i]);
          context.lineTo(p.x, p.y);
        }
        context.stroke();
      }

      function draw() {
        const rect = canvas.getBoundingClientRect();
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, rect.width, rect.height);
        ctx.lineCap = "round";
        ctx.lineJoin = "round";
        ctx.strokeStyle = "#111827";
        ctx.fillStyle = "#111827";
        ctx.lineWidth = Math.max(8, rect.width * 0.032);

        for (const stroke of strokes) {
          drawStroke(ctx, stroke);
        }
        if (currentStroke) {
          drawStroke(ctx, currentStroke);
        }
      }

      function getBounds(items) {
        let minX = Infinity;
        let minY = Infinity;
        let maxX = -Infinity;
        let maxY = -Infinity;
        for (const stroke of items) {
          for (const p of stroke) {
            minX = Math.min(minX, p.x);
            minY = Math.min(minY, p.y);
            maxX = Math.max(maxX, p.x);
            maxY = Math.max(maxY, p.y);
          }
        }
        if (!Number.isFinite(minX)) return null;
        return { minX, minY, maxX, maxY, width: maxX - minX, height: maxY - minY };
      }

      function exportCanvas() {
        const size = 512;
        const out = document.createElement("canvas");
        out.width = size;
        out.height = size;
        const octx = out.getContext("2d");
        const bounds = getBounds(strokes);

        octx.fillStyle = "#ffffff";
        octx.fillRect(0, 0, size, size);
        if (!bounds) return out.toDataURL("image/png");

        const padding = 58;
        const scale = Math.min(
          (size - padding * 2) / Math.max(bounds.width, 1),
          (size - padding * 2) / Math.max(bounds.height, 1)
        );
        const tx = (size - bounds.width * scale) / 2 - bounds.minX * scale;
        const ty = (size - bounds.height * scale) / 2 - bounds.minY * scale;

        octx.lineCap = "round";
        octx.lineJoin = "round";
        octx.strokeStyle = "#111827";
        octx.fillStyle = "#111827";
        octx.lineWidth = 22;

        for (const stroke of strokes) {
          drawStroke(octx, stroke, (p) => ({ x: p.x * scale + tx, y: p.y * scale + ty }));
        }
        return out.toDataURL("image/png");
      }

      function normalizeSymbol(value) {
        const text = String(value || "").trim();
        for (const raw of text) {
          if (raw === "-" || raw === "–" || raw === "—" || raw === "_") return NONE_SYMBOL;
          const upper = raw.toLocaleUpperCase("ru-RU");
          if (ALLOWED.includes(upper)) return upper;
        }
        return "";
      }

      function normalizeWord(value) {
        return String(value || "").replace(/ё/g, "е").replace(/Ё/g, "Е").toLocaleLowerCase("ru-RU");
      }

      function taskUrls() {
        return { health: "", words: "" };
      }

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        })[char]);
      }

      function renderMasked(value) {
        return escapeHtml(value).replace("_", '<span class="gap">?</span>');
      }

      function shuffled(items) {
        const out = items.slice();
        for (let i = out.length - 1; i > 0; i -= 1) {
          const j = Math.floor(Math.random() * (i + 1));
          [out[i], out[j]] = [out[j], out[i]];
        }
        return out;
      }

      function makeStressItems(groups) {
        return Object.entries(groups).flatMap(([group, text]) => {
          return String(text || "")
            .trim()
            .split(/\s+/)
            .filter(Boolean)
            .map((source, index) => {
              let stress = -1;
              const wordChars = Array.from(source).map((char, charIndex) => {
                if (STRESSED_VOWELS.has(char)) stress = charIndex;
                return char.toLocaleLowerCase("ru-RU");
              });
              const quizChars = wordChars.map((char) => char === "ё" ? "е" : char);
              const vowelPositions = quizChars
                .map((char, charIndex) => VOWELS.has(char) ? charIndex : -1)
                .filter((charIndex) => charIndex >= 0);
              if (stress < 0 || vowelPositions.length < 1) return null;
              return {
                id: `stress:${group}:${index}:${quizChars.join("")}`,
                group,
                source,
                word: wordChars.join(""),
                quiz: quizChars.join(""),
                stress,
                vowelPositions
              };
            })
            .filter(Boolean);
        });
      }

      function makeFormItems(groups) {
        return (Array.isArray(groups) ? groups : []).flatMap((group) => {
          const pairs = Array.isArray(group.pairs) ? group.pairs : [];
          return pairs.map((pair, index) => {
            const prompt = Array.isArray(pair) ? pair[0] : pair.prompt;
            const correct = Array.isArray(pair) ? pair[1] : pair.correct;
            const wrong = Array.isArray(pair) ? pair[2] : pair.wrong;
            if (!prompt || !correct || !wrong) return null;
            return {
              id: `forms:${group.name || "group"}:${index}:${prompt}`,
              group: group.name || "Формы",
              note: group.note || "",
              prompt,
              correct,
              wrong
            };
          }).filter(Boolean);
        });
      }

      function applyTheme(theme) {
        const normalized = theme === "dark" ? "dark" : "light";
        document.body.dataset.theme = normalized;
        window.localStorage.setItem(THEME_KEY, normalized);
        document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
          button.textContent = normalized === "dark" ? "Тема: тёмная" : "Тема: светлая";
          button.setAttribute("aria-pressed", normalized === "dark" ? "true" : "false");
        });
      }

      function toggleTheme() {
        applyTheme(document.body.dataset.theme === "dark" ? "light" : "dark");
      }

      function showHome() {
        activeApp = "home";
        homeScreen.hidden = false;
        handwritingApp.hidden = true;
        extraTrainerApp.hidden = true;
      }

      function openHandwriting(taskId = selectedTask) {
        activeApp = "handwriting";
        homeScreen.hidden = true;
        handwritingApp.hidden = false;
        extraTrainerApp.hidden = true;
        selectTask(taskId);
        window.setTimeout(resizeCanvas, 0);
      }

      function openExtra(mode) {
        activeApp = mode === "forms" ? "forms" : "stress";
        homeScreen.hidden = true;
        handwritingApp.hidden = true;
        extraTrainerApp.hidden = false;
        setupExtraMode(activeApp);
      }

      function applyAnswerStats(target, ok) {
        target.done += 1;
        if (ok) {
          target.correct += 1;
          target.goodStreak = (target.goodStreak || 0) + 1;
          target.badStreak = 0;
        } else {
          target.wrong += 1;
          target.badStreak = (target.badStreak || 0) + 1;
          target.goodStreak = 0;
        }
      }

      function extraItemKey(item) {
        return item ? `${extraMode}:${item.id}` : "";
      }

      function cleanExtraHard(source) {
        if (!source || typeof source !== "object") return {};
        const cleaned = {};
        for (const [key, item] of Object.entries(source)) {
          if (item && item.id && (item.kind === "stress" || item.kind === "forms")) cleaned[key] = item;
        }
        return cleaned;
      }

      function loadExtraHard() {
        try {
          return cleanExtraHard(JSON.parse(window.localStorage.getItem(EXTRA_HARD_KEY) || "{}"));
        } catch {
          return {};
        }
      }

      function saveExtraHard() {
        window.localStorage.setItem(EXTRA_HARD_KEY, JSON.stringify(extraHard));
      }

      function markExtraHard(reason = "manual") {
        if (!extraCurrent) return;
        const key = extraItemKey(extraCurrent);
        extraHard[key] = {
          id: extraCurrent.id,
          kind: extraMode,
          reason,
          updatedAt: Date.now()
        };
        saveExtraHard();
        updateExtraStats();
        updateExtraHardStatus();
      }

      function removeExtraHard() {
        if (!extraCurrent) return;
        delete extraHard[extraItemKey(extraCurrent)];
        saveExtraHard();
        if (extraStudyMode === "hard") {
          buildExtraQueue();
          nextExtra();
        }
        updateExtraStats();
        updateExtraHardStatus();
      }

      function extraHardCountForMode() {
        return Object.values(extraHard).filter((item) => item.kind === extraMode).length;
      }

      function updateExtraModeTabs() {
        for (const button of extraModeTabs.querySelectorAll("button[data-extra-study]")) {
          button.classList.toggle("active", button.dataset.extraStudy === extraStudyMode);
        }
      }

      function updateExtraHardStatus() {
        const isHard = !!extraHard[extraItemKey(extraCurrent)];
        const total = extraHardCountForMode();
        extraHardStatus.textContent = isHard
          ? `Это задание в сложных. Всего сложных здесь: ${total}.`
          : `Ошибки попадут в сложные автоматически. Сейчас сложных: ${total}.`;
      }

      function extraSourceItems() {
        const all = extraMode === "forms" ? formItems : stressItems;
        const source = extraStudyMode === "hard"
          ? all.filter((item) => extraHard[`${extraMode}:${item.id}`])
          : all;
        return extraCategory === "Все"
          ? source
          : source.filter((item) => item.group === extraCategory);
      }

      function updateExtraStats() {
        const total = extraSourceItems().length;
        extraDone.textContent = String(extraStats.done);
        extraCorrect.textContent = String(extraStats.correct);
        extraWrong.textContent = String(extraStats.wrong);
        extraGoodStreak.textContent = String(extraStats.goodStreak || 0);
        extraBadStreak.textContent = String(extraStats.badStreak || 0);
        extraTotal.textContent = String(total);
        extraHardCount.textContent = String(extraHardCountForMode());
        updateExtraHardStatus();
      }

      function renderExtraCategories() {
        const all = extraMode === "forms" ? formItems : stressItems;
        const source = extraStudyMode === "hard"
          ? all.filter((item) => extraHard[`${extraMode}:${item.id}`])
          : all;
        const groups = ["Все", ...Array.from(new Set(source.map((item) => item.group)))];
        extraCategories.innerHTML = groups.map((group) => {
          const count = group === "Все" ? source.length : source.filter((item) => item.group === group).length;
          return `<button type="button" class="${group === extraCategory ? "active" : ""}" data-category="${escapeHtml(group)}">${escapeHtml(group)} · ${count}</button>`;
        }).join("");
      }

      function setupExtraMode(mode) {
        extraMode = mode === "forms" ? "forms" : "stress";
        extraStudyMode = "practice";
        extraCategory = "Все";
        extraStats = makeEmptyStats();
        extraTitle.textContent = extraMode === "forms" ? "Формы слов" : "Ударения";
        extraSubtitle.textContent = extraMode === "forms"
          ? "Выберите правильную форму слова. Ошибка сразу показывает правильный вариант."
          : "Нажмите гласную, на которую падает ударение.";
        updateExtraModeTabs();
        renderExtraCategories();
        buildExtraQueue();
        nextExtra();
      }

      function buildExtraQueue() {
        extraQueue = shuffled(extraSourceItems());
        extraIndex = -1;
        extraCurrent = null;
        extraAnswered = false;
        updateExtraStats();
      }

      function nextExtra() {
        if (!extraQueue.length) buildExtraQueue();
        if (!extraQueue.length) {
          extraCurrent = null;
          extraKind.textContent = "Нет заданий";
          extraPrompt.textContent = "Список пуст";
          extraOptions.innerHTML = "";
          extraFeedback.textContent = extraStudyMode === "hard"
            ? "В сложных пока пусто. Ошибитесь в обычной тренировке или добавьте задание кнопкой «В сложные»."
            : "В этом разделе пока нет данных.";
          extraFeedback.className = "extra-feedback";
          updateExtraStats();
          return;
        }
        extraIndex = (extraIndex + 1) % extraQueue.length;
        if (extraIndex === 0) extraQueue = shuffled(extraQueue);
        extraCurrent = extraQueue[extraIndex];
        extraAnswered = false;
        renderExtraCard();
      }

      function stressAnswerText(item) {
        return Array.from(item.word).map((char, index) => (
          index === item.stress ? char.toLocaleUpperCase("ru-RU") : char
        )).join("");
      }

      function renderExtraCard() {
        if (!extraCurrent) return;
        extraKind.textContent = extraCurrent.group;
        extraFeedback.textContent = extraMode === "forms"
          ? "Выберите правильный вариант."
          : "Нажмите ударную гласную.";
        extraFeedback.className = "extra-feedback";

        if (extraMode === "forms") {
          const options = shuffled([extraCurrent.correct, extraCurrent.wrong]);
          extraPrompt.textContent = extraCurrent.prompt;
          extraOptions.innerHTML = options.map((answer) => {
            const correct = answer === extraCurrent.correct ? "true" : "false";
            return `<button type="button" data-correct="${correct}">${escapeHtml(answer)}</button>`;
          }).join("");
        } else {
          const vowels = new Set(extraCurrent.vowelPositions);
          extraPrompt.innerHTML = `<div class="stress-word">${Array.from(extraCurrent.quiz).map((char, index) => {
            if (!vowels.has(index)) return `<span class="stress-letter">${escapeHtml(char)}</span>`;
            return `<button type="button" class="stress-letter" data-index="${index}">${escapeHtml(char)}</button>`;
          }).join("")}</div>`;
          extraOptions.innerHTML = "";
        }
        updateExtraStats();
      }

      function finishExtraAnswer(ok, rightText, wrongText = "") {
        applyAnswerStats(extraStats, ok);
        if (!ok) markExtraHard("wrong");
        extraAnswered = true;
        extraFeedback.textContent = ok
          ? `Верно: ${rightText}.`
          : `Неверно${wrongText ? `: ${wrongText}` : ""}. Правильно: ${rightText}.`;
        extraFeedback.className = `extra-feedback ${ok ? "good" : "bad"}`;
        updateExtraStats();
        if (ok) {
          window.setTimeout(() => {
            if (extraAnswered) nextExtra();
          }, 750);
        }
      }

      function answerExtraStress(index) {
        if (extraAnswered || !extraCurrent) return;
        const ok = index === extraCurrent.stress;
        extraPrompt.querySelectorAll("button.stress-letter").forEach((button) => {
          const buttonIndex = Number(button.dataset.index);
          if (buttonIndex === extraCurrent.stress) button.classList.add("correct");
          if (buttonIndex === index && !ok) button.classList.add("wrong");
          button.disabled = true;
        });
        finishExtraAnswer(ok, stressAnswerText(extraCurrent), Array.from(extraCurrent.quiz)[index] || "");
      }

      function answerExtraForm(button) {
        if (extraAnswered || !extraCurrent || !button) return;
        const ok = button.dataset.correct === "true";
        extraOptions.querySelectorAll("button").forEach((option) => {
          if (option.dataset.correct === "true") option.classList.add("correct");
          if (option === button && !ok) option.classList.add("wrong");
          option.disabled = true;
        });
        finishExtraAnswer(ok, extraCurrent.correct, button.textContent.trim());
      }

      function gapIndex(masked) {
        return String(masked || "").indexOf("_");
      }

      function expectedLetter(task) {
        if (!task) return "";
        if (normalizeWord(task.masked.replace("_", "")) === normalizeWord(task.answer)) return NONE_SYMBOL;
        const index = gapIndex(task.masked);
        if (index < 0 || index >= task.answer.length) return "";
        return normalizeSymbol(task.answer[index]);
      }

      function letterForAnswerCase(task, symbol) {
        const index = gapIndex(task.masked);
        const answerChar = index >= 0 ? task.answer[index] : "";
        return answerChar === answerChar.toLocaleUpperCase("ru-RU")
          ? symbol
          : symbol.toLocaleLowerCase("ru-RU");
      }

      function fillMaskedWord(task, symbol) {
        if (!task || !symbol) return "";
        if (symbol === NONE_SYMBOL) return task.masked.replace("_", "");
        return task.masked.replace("_", letterForAnswerCase(task, symbol));
      }

      function coerceForTask(symbol) {
        return normalizeSymbol(symbol);
      }

      function makeEmptyStats() {
        return { done: 0, correct: 0, wrong: 0, goodStreak: 0, badStreak: 0, quizCorrect: 0, quizTotal: 0 };
      }

      function pairKey(pair) {
        if (!pair) return "";
        return pair.id || `${pair.task || selectedTask}:${pair.masked}:${pair.answer}`;
      }

      function cleanHardWords(source) {
        if (!source || typeof source !== "object") return {};
        const cleaned = {};
        for (const [key, item] of Object.entries(source)) {
          if (item && item.masked && item.answer) cleaned[key] = item;
        }
        return cleaned;
      }

      function loadHardWords() {
        const embedded = cleanHardWords(DEFAULT_MEMORY.hardWords);
        try {
          const parsed = JSON.parse(window.localStorage.getItem(HARD_WORDS_KEY) || "{}");
          return { ...embedded, ...cleanHardWords(parsed) };
        } catch {
          return embedded;
        }
      }

      function saveHardWords() {
        window.localStorage.setItem(HARD_WORDS_KEY, JSON.stringify(hardWords));
      }

      function hardList() {
        return Object.values(hardWords)
          .filter((item) => item && item.masked && item.answer)
          .sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
      }

      function updateStats() {
        statDone.textContent = String(stats.done);
        statCorrect.textContent = String(stats.correct);
        statWrong.textContent = String(stats.wrong);
        statHard.textContent = String(hardList().length);
        statGoodStreak.textContent = String(stats.goodStreak || 0);
        statBadStreak.textContent = String(stats.badStreak || 0);
        const isHard = !!hardWords[pairKey(currentTask)];
        hardStatus.textContent = isHard
          ? "Это слово отмечено как сложное."
          : "Сложные слова сохраняются отдельно от почерка.";
      }

      function setMode(mode) {
        currentMode = mode;
        quizActive = mode === "quiz" && quizActive;
        for (const button of modeTabs.querySelectorAll("button")) {
          button.classList.toggle("active", button.dataset.mode === mode);
        }
        currentTaskIndex = -1;
        if (mode === "hard") {
          wordPairs = hardList();
          if (!wordPairs.length) {
            maskedWord.textContent = "Пока пусто";
            filledWord.textContent = "?";
            taskProgress.textContent = "Отмечайте сложные слова кнопкой ниже или ошибайтесь в тренировке.";
            taskFeedback.textContent = "Сложные слова появятся здесь автоматически.";
            updateStats();
            return;
          }
          nextTask();
          return;
        }
        if (mode === "quiz") {
          startQuiz();
          return;
        }
        wordPairs = allPairs.slice();
        nextTask();
      }

      function selectTask(taskId) {
        selectedTask = taskId;
        quizActive = false;
        currentMode = "practice";
        stats = makeEmptyStats();
        for (const button of taskTabs.querySelectorAll("button")) {
          button.classList.toggle("active", button.dataset.task === taskId);
        }
        for (const button of modeTabs.querySelectorAll("button")) {
          button.classList.toggle("active", button.dataset.mode === "practice");
        }
        loadWords();
      }

      function markHard(reason = "manual") {
        if (!currentTask) return;
        hardWords[pairKey(currentTask)] = {
          ...currentTask,
          reason,
          updatedAt: Date.now()
        };
        saveHardWords();
        updateStats();
      }

      function removeHard() {
        if (!currentTask) return;
        delete hardWords[pairKey(currentTask)];
        saveHardWords();
        if (currentMode === "hard") {
          wordPairs = hardList();
          currentTaskIndex = Math.min(currentTaskIndex - 1, wordPairs.length - 1);
          nextTask();
        }
        updateStats();
      }

      async function loadWords() {
        try {
          const pairs = selectedTask === "all"
            ? Object.values(STATIC_WORDS).flat()
            : (STATIC_WORDS[selectedTask] || []);
          allPairs = pairs.map((item) => ({ ...item }));
          if (!allPairs.length) throw new Error("Список слов пустой.");
          wordPairs = allPairs.slice();
          currentTaskIndex = -1;
          stats = makeEmptyStats();
          if (currentMode === "hard") {
            setMode("hard");
          } else if (currentMode === "quiz") {
            startQuiz();
          } else {
            nextTask();
          }
        } catch (error) {
          maskedWord.textContent = "Нет списка";
          filledWord.textContent = "?";
          taskProgress.textContent = "Слова вшиты в файл, но список не прочитался.";
          taskFeedback.textContent = "Не удалось загрузить слова: " + (error.message || error);
        }
      }

      function nextTask() {
        if (quizActive && currentMode === "quiz" && currentTaskIndex >= quizQueue.length - 1) {
          finishQuiz();
          return;
        }
        if (!wordPairs.length) {
          maskedWord.textContent = "Загрузка...";
          filledWord.textContent = "?";
          return;
        }
        currentTaskIndex = (currentTaskIndex + 1) % wordPairs.length;
        currentTask = wordPairs[currentTaskIndex];
        maskedWord.innerHTML = renderMasked(currentTask.masked);
        filledWord.textContent = "?";
        filledWord.className = "word";
        const taskLabel = currentTask.task ? `Задание ${currentTask.task}. ` : "";
        const quizLabel = quizActive ? `Контрольная: ${currentTaskIndex + 1}/${wordPairs.length}. ` : "";
        taskProgress.textContent = `${quizLabel}${taskLabel}${currentTaskIndex + 1} из ${wordPairs.length}.`;
        taskFeedback.textContent = "Нарисуйте пропущенную букву слева.";
        updateStats();
        clearDrawing(false);
      }

      function shuffleTasks() {
        for (let i = wordPairs.length - 1; i > 0; i -= 1) {
          const j = Math.floor(Math.random() * (i + 1));
          [wordPairs[i], wordPairs[j]] = [wordPairs[j], wordPairs[i]];
        }
        currentTaskIndex = -1;
        stats = makeEmptyStats();
        nextTask();
      }

      function startQuiz() {
        if (!allPairs.length) return;
        currentMode = "quiz";
        quizActive = true;
        stats = makeEmptyStats();
        const source = currentMode === "hard" && hardList().length ? hardList() : allPairs;
        quizQueue = source.slice().sort(() => Math.random() - 0.5).slice(0, QUIZ_SIZE);
        wordPairs = quizQueue;
        currentTaskIndex = -1;
        for (const button of modeTabs.querySelectorAll("button")) {
          button.classList.toggle("active", button.dataset.mode === "quiz");
        }
        setStatus("Контрольная началась: 15 слов, ошибки сохраняются в сложные.", "quiz");
        nextTask();
      }

      function finishQuiz() {
        quizActive = false;
        maskedWord.textContent = "Контрольная завершена";
        filledWord.textContent = `${stats.correct}/${stats.done}`;
        filledWord.className = stats.correct === stats.done ? "word good" : "word bad";
        taskProgress.textContent = `Итог: ${stats.correct} из ${stats.done}. Ошибок: ${stats.wrong}.`;
        taskFeedback.textContent = stats.wrong
          ? "Ошибочные слова добавлены в сложные."
          : "Отлично, всё правильно.";
        setStatus(`Контрольная: ${stats.correct}/${stats.done}.`, stats.wrong ? "bad" : "good");
        updateStats();
      }

      function handleTaskAnswer(rawSymbol, confidence, source) {
        const recognized = normalizeSymbol(rawSymbol);
        if (!recognized) return false;
        if (!currentTask) return false;

        const symbol = coerceForTask(recognized);
        const filled = fillMaskedWord(currentTask, symbol);
        const ok = normalizeWord(filled) === normalizeWord(currentTask.answer);
        const corrected = symbol !== recognized;

        filledWord.textContent = filled;
        filledWord.className = `word ${ok ? "good" : "bad"}`;
        applyAnswerStats(stats, ok);

        if (ok) {
          taskFeedback.textContent = corrected
            ? `Зачтено. Распознано ${recognized}, но для этого слова подходит ${symbol}.`
            : `Верно: ${currentTask.answer}.`;
          taskProgress.textContent = quizActive
            ? `Контрольная: ${stats.correct}/${stats.done}.`
            : `${currentTaskIndex + 1} из ${wordPairs.length}. Верно: ${stats.correct}.`;
          window.setTimeout(() => {
            if (currentTask && normalizeWord(filledWord.textContent) === normalizeWord(filled)) {
              nextTask();
            }
          }, 950);
        } else {
          markHard("wrong");
          taskFeedback.textContent = `Неверно. Вы написали: ${filled}. Правильно: ${currentTask.answer}.`;
          if (quizActive) {
            window.setTimeout(() => {
              if (currentTask && normalizeWord(filledWord.textContent) === normalizeWord(filled)) {
                nextTask();
              }
            }, 1500);
          }
        }

        updateStats();
        showResult(symbol, symbol, confidence, ok ? `Задание зачтено: ${symbol}.` : `Не зачтено: нужна другая буква.`, ok ? "good" : "bad");
        return true;
      }

      function cleanPersonalSamples(source) {
        const cleaned = {};
        if (!source || typeof source !== "object") source = {};
        for (const letter of ALLOWED) {
          const items = Array.isArray(source[letter]) ? source[letter] : [];
          cleaned[letter] = items
            .filter((item) => item && Array.isArray(item.vector) && item.vector.length === TEMPLATE_SIZE * TEMPLATE_SIZE)
            .slice(0, MAX_SAMPLES_PER_LETTER);
        }
        return cleaned;
      }

      function mergePersonalSamples(embedded, local) {
        const merged = {};
        for (const letter of ALLOWED) {
          merged[letter] = [
            ...(local[letter] || []),
            ...(embedded[letter] || [])
          ].slice(0, MAX_SAMPLES_PER_LETTER);
        }
        return merged;
      }

      function loadPersonalSamples() {
        const embedded = cleanPersonalSamples(DEFAULT_MEMORY.personalSamples);
        try {
          const raw = window.localStorage.getItem(TRAINING_KEY);
          const parsed = raw ? JSON.parse(raw) : {};
          return mergePersonalSamples(embedded, cleanPersonalSamples(parsed));
        } catch {
          return embedded;
        }
      }

      function savePersonalSamples() {
        window.localStorage.setItem(TRAINING_KEY, JSON.stringify(personalSamples));
      }

      function totalPersonalSamples() {
        return ALLOWED.reduce((sum, letter) => sum + (personalSamples[letter] || []).length, 0);
      }

      function updateTrainingUI() {
        const selected = trainLetter.value || ALLOWED[0];
        const current = (personalSamples[selected] || []).length;
        const total = totalPersonalSamples();
        trainingBadge.textContent = String(total);
        sampleCount.textContent = total
          ? `Для ${selected}: ${current}. Всего личных примеров: ${total}.`
          : "Личных примеров пока нет.";
        for (const button of trainLetterGrid.querySelectorAll("button")) {
          button.classList.toggle("selected", button.dataset.letter === selected);
          const count = (personalSamples[button.dataset.letter] || []).length;
          button.title = count ? `${button.dataset.letter}: ${count} прим.` : `Учить ${button.dataset.letter}`;
        }
      }

      function makeTrainingSample() {
        const bounds = getBounds(strokes);
        if (!bounds) return null;

        const out = document.createElement("canvas");
        out.width = TEMPLATE_SIZE;
        out.height = TEMPLATE_SIZE;
        const octx = out.getContext("2d", { willReadFrequently: true });
        octx.fillStyle = "#ffffff";
        octx.fillRect(0, 0, TEMPLATE_SIZE, TEMPLATE_SIZE);

        const padding = 5;
        const scale = Math.min(
          (TEMPLATE_SIZE - padding * 2) / Math.max(bounds.width, 1),
          (TEMPLATE_SIZE - padding * 2) / Math.max(bounds.height, 1)
        );
        const tx = (TEMPLATE_SIZE - bounds.width * scale) / 2 - bounds.minX * scale;
        const ty = (TEMPLATE_SIZE - bounds.height * scale) / 2 - bounds.minY * scale;

        octx.lineCap = "round";
        octx.lineJoin = "round";
        octx.strokeStyle = "#000000";
        octx.fillStyle = "#000000";
        octx.lineWidth = Math.max(4, TEMPLATE_SIZE * 0.105);

        for (const stroke of strokes) {
          drawStroke(octx, stroke, (p) => ({ x: p.x * scale + tx, y: p.y * scale + ty }));
        }

        const image = octx.getImageData(0, 0, TEMPLATE_SIZE, TEMPLATE_SIZE).data;
        const vector = [];
        for (let i = 0; i < image.length; i += 4) {
          const gray = (image[i] + image[i + 1] + image[i + 2]) / 3;
          vector.push(Math.max(0, Math.min(255, Math.round(255 - gray))));
        }

        return {
          vector,
          strokes: strokes.length,
          createdAt: Date.now()
        };
      }

      function detectDashSymbol() {
        const bounds = getBounds(strokes);
        if (!bounds) return null;
        const width = Math.max(bounds.width, 1);
        const height = Math.max(bounds.height, 1);
        const pointCount = strokes.reduce((sum, stroke) => sum + stroke.length, 0);
        const aspect = width / height;
        const canvasSize = Math.min(canvas.clientWidth || 1, canvas.clientHeight || 1);
        const longEnough = width > canvasSize * 0.18;
        const flatEnough = aspect > 3.2 && height < canvasSize * 0.22;
        const simpleEnough = strokes.length <= 2 && pointCount <= 90;
        if (longEnough && flatEnough && simpleEnough) {
          return {
            label: NONE_SYMBOL,
            confidence: Math.min(96, Math.round(72 + Math.min(20, aspect * 2)))
          };
        }
        return null;
      }

      function compareSamples(a, b) {
        let dot = 0;
        let a2 = 0;
        let b2 = 0;
        let l1 = 0;
        let intersection = 0;
        let union = 0;

        for (let i = 0; i < a.vector.length; i += 1) {
          const av = a.vector[i] / 255;
          const bv = b.vector[i] / 255;
          dot += av * bv;
          a2 += av * av;
          b2 += bv * bv;
          l1 += Math.abs(av - bv);

          const ai = av > 0.18;
          const bi = bv > 0.18;
          if (ai && bi) intersection += 1;
          if (ai || bi) union += 1;
        }

        const cosine = dot / (Math.sqrt(a2) * Math.sqrt(b2) + 1e-6);
        const soft = 1 - (l1 / a.vector.length);
        const iou = union ? intersection / union : 0;
        const strokePenalty = Math.min(0.12, Math.abs((a.strokes || 1) - (b.strokes || 1)) * 0.025);
        return Math.max(0, Math.min(1, cosine * 0.48 + soft * 0.27 + iou * 0.25 - strokePenalty));
      }

      function matchPersonalSample() {
        const sample = makeTrainingSample();
        if (!sample) return null;

        let best = null;
        let secondScore = 0;
        for (const letter of ALLOWED) {
          const items = personalSamples[letter] || [];
          for (const item of items) {
            const score = compareSamples(sample, item);
            if (!best || score > best.score) {
              secondScore = best ? best.score : 0;
              best = { label: letter, score };
            } else if (score > secondScore) {
              secondScore = score;
            }
          }
        }

        if (!best) return null;
        best.margin = best.score - secondScore;
        best.confidence = Math.round(Math.max(0, Math.min(1, best.score * 0.82 + best.margin * 0.9)) * 100);
        return best;
      }

      function showResult(symbol, text, confidence, message, type = "good") {
        symbolEl.textContent = symbol || "?";
        recognizedText.textContent = text || symbol || "Не распознано";
        confidenceFill.style.width = `${Math.max(0, Math.min(100, confidence || 0))}%`;
        setStatus(message, type);
      }

      function isTrainingMode() {
        return Boolean(trainModeToggle && trainModeToggle.checked);
      }

      function stopPendingRecognition() {
        window.clearTimeout(autoRecognizeTimer);
        recognizeSerial += 1;
      }

      function setTrainingMode(enabled, message) {
        if (trainModeToggle) trainModeToggle.checked = enabled;
        stopPendingRecognition();
        if (message) setStatus(message, enabled ? "quiz" : "good");
      }

      function scheduleRecognize(delay = 650) {
        window.clearTimeout(autoRecognizeTimer);
        if (isTrainingMode()) return;
        const pointCount = strokes.reduce((sum, stroke) => sum + stroke.length, 0);
        if (pointCount < 2) return;
        autoRecognizeTimer = window.setTimeout(() => {
          recognize(true);
        }, delay);
      }

      function clearDrawing(resetResult = true) {
        window.clearTimeout(autoRecognizeTimer);
        recognizeSerial += 1;
        strokes = [];
        currentStroke = null;
        activePointer = null;
        if (resetResult) {
          symbolEl.textContent = "?";
          recognizedText.textContent = "Пусто";
          confidenceFill.style.width = "0%";
          setStatus("Очищено.");
        }
        draw();
      }

      function saveCurrentSample(options = {}) {
        stopPendingRecognition();
        const pointCount = strokes.reduce((sum, stroke) => sum + stroke.length, 0);
        if (pointCount < 2) {
          setStatus("Сначала нарисуйте букву слева, потом сохраняйте пример.", "bad");
          return;
        }

        const letter = trainLetter.value;
        const sample = makeTrainingSample();
        if (!sample || !letter) return;
        personalSamples[letter] = personalSamples[letter] || [];
        personalSamples[letter].unshift(sample);
        personalSamples[letter] = personalSamples[letter].slice(0, MAX_SAMPLES_PER_LETTER);
        savePersonalSamples();
        updateTrainingUI();
        const count = (personalSamples[letter] || []).length;
        showResult(letter, letter, 100, `Запомнил ${letter}. Для ${letter}: ${count} прим. Теперь можно нарисовать ещё вариант.`, "good");
        if (options.clearAfter) {
          clearDrawing(false);
        }
      }

      function clearCurrentLetterSamples() {
        const letter = trainLetter.value;
        const count = (personalSamples[letter] || []).length;
        if (count && !window.confirm(`Удалить ${count} прим. для ${letter}? Остальная память не пострадает.`)) {
          return;
        }
        personalSamples[letter] = [];
        savePersonalSamples();
        updateTrainingUI();
        setStatus(`Примеры для ${letter} удалены.`);
      }

      function clearAllSamples() {
        personalSamples = {};
        savePersonalSamples();
        updateTrainingUI();
        setStatus("Все личные примеры удалены.");
      }

      async function checkBackend() {
        setStatus("Статический режим: backend не нужен, слова вшиты в HTML. Почерк хранится в браузере.", "good");
        return true;
      }

      async function recognize(isAuto = false) {
        window.clearTimeout(autoRecognizeTimer);
        const requestId = ++recognizeSerial;
        const pointCount = strokes.reduce((sum, stroke) => sum + stroke.length, 0);
        if (pointCount < 2) {
          setStatus("Сначала нарисуйте символ.", "bad");
          return;
        }

        const expected = expectedLetter(currentTask);
        const dash = detectDashSymbol();
        if (dash) {
          if (handleTaskAnswer(dash.label, dash.confidence, "dash")) return;
          showResult(dash.label, "Ничего не вставлять", dash.confidence, "Распознан прочерк: ничего не вставлять.", "good");
          return;
        }

        const personal = matchPersonalSample();
        if (personal && (personal.score >= 0.18 || personal.margin >= 0.035)) {
          if (handleTaskAnswer(personal.label, Math.max(62, personal.confidence), "personal")) {
            return;
          }
          showResult(
            personal.label,
            personal.label,
            Math.max(62, personal.confidence),
            "Личный почерк: " + personal.label + ". Совпадение " + (personal.score * 100).toFixed(0) + "%.",
            "good"
          );
          return;
        }

        const trained = totalPersonalSamples();
        if (trained === 0) {
          setStatus("Добавьте примеры в блоке «Мой почерк», чтобы распознавание подстроилось под вас.", "bad");
          taskFeedback.textContent = "Нужна база почерка: выберите букву справа, нарисуйте и нажмите «Запомнить».";
        } else {
          setStatus("Не уверен в букве. Добавьте ещё 2-3 примера этой буквы в «Мой почерк».", "bad");
          taskFeedback.textContent = expected
            ? "Не распознал уверенно. Для этого слова нужна буква " + expected + "; добавьте её пример в почерк."
            : "Не распознал уверенно. Добавьте пример этой буквы.";
        }
        symbolEl.textContent = "?";
        recognizedText.textContent = "Нужен пример";
        confidenceFill.style.width = "0%";
      }

      canvas.addEventListener("pointerdown", (event) => {
        window.clearTimeout(autoRecognizeTimer);
        activePointer = event.pointerId;
        canvas.setPointerCapture(activePointer);
        currentStroke = [pointFromEvent(event)];
        draw();
      });

      canvas.addEventListener("pointermove", (event) => {
        if (event.pointerId !== activePointer || !currentStroke) return;
        currentStroke.push(pointFromEvent(event));
        draw();
      });

      function finish(event) {
        if (event.pointerId !== activePointer || !currentStroke) return;
        if (currentStroke.length) strokes.push(currentStroke);
        currentStroke = null;
        activePointer = null;
        draw();
        if (isTrainingMode()) {
          const letter = trainLetter.value || ALLOWED[0];
          setStatus(`Режим обучения: ${letter} готова. Нажмите «Запомнить».`, "quiz");
          return;
        }
        scheduleRecognize();
      }

      canvas.addEventListener("pointerup", finish);
      canvas.addEventListener("pointercancel", finish);

      undoButton.addEventListener("click", () => {
        strokes.pop();
        draw();
        if (isTrainingMode()) {
          const letter = trainLetter.value || ALLOWED[0];
          setStatus(`Штрих отменён. Режим обучения для ${letter} всё ещё включён.`, "quiz");
          return;
        }
        scheduleRecognize(300);
      });

      clearButton.addEventListener("click", () => {
        clearDrawing(true);
      });

      predictButton.addEventListener("click", recognize);
      if (checkButton) checkButton.addEventListener("click", checkBackend);
      trainLetter.addEventListener("change", () => {
        updateTrainingUI();
        setTrainingMode(true, trainLetter.value === NONE_SYMBOL
          ? "Режим обучения для прочерка: нарисуйте горизонтальный штрих и нажмите «Запомнить»."
          : `Режим обучения для ${trainLetter.value}: нарисуйте букву и нажмите «Запомнить».`);
      });
      trainModeToggle.addEventListener("change", () => {
        if (isTrainingMode()) {
          setTrainingMode(true, trainLetter.value === NONE_SYMBOL
            ? "Режим обучения для прочерка: автопроверка выключена."
            : `Режим обучения для ${trainLetter.value}: автопроверка выключена.`);
        } else {
          stopPendingRecognition();
          setStatus("Режим обучения выключен. Автораспознавание снова работает.", "good");
          scheduleRecognize(250);
        }
      });
      saveSampleButton.addEventListener("click", saveCurrentSample);
      saveAndClearSampleButton.addEventListener("click", () => saveCurrentSample({ clearAfter: true }));
      clearLetterButton.addEventListener("click", clearCurrentLetterSamples);
      nextTaskButton.addEventListener("click", nextTask);
      shuffleButton.addEventListener("click", shuffleTasks);
      quizButton.addEventListener("click", startQuiz);
      markHardButton.addEventListener("click", () => {
        markHard("manual");
        setStatus("Слово добавлено в сложные.", "quiz");
      });
      removeHardButton.addEventListener("click", removeHard);
      modeTabs.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-mode]");
        if (button) setMode(button.dataset.mode);
      });
      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.addEventListener("click", toggleTheme);
      });
      document.querySelectorAll("[data-go-home]").forEach((button) => {
        button.addEventListener("click", showHome);
      });
      document.querySelectorAll("[data-open-app]").forEach((button) => {
        button.addEventListener("click", () => {
          const app = button.dataset.openApp;
          if (app === "handwriting") {
            openHandwriting(button.dataset.task || selectedTask);
          } else {
            openExtra(app);
          }
        });
      });
      extraModeTabs.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-extra-study]");
        if (!button) return;
        extraStudyMode = button.dataset.extraStudy === "hard" ? "hard" : "practice";
        extraCategory = "Все";
        extraStats = makeEmptyStats();
        updateExtraModeTabs();
        renderExtraCategories();
        buildExtraQueue();
        nextExtra();
      });
      extraCategories.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-category]");
        if (!button) return;
        extraCategory = button.dataset.category;
        extraStats = makeEmptyStats();
        renderExtraCategories();
        buildExtraQueue();
        nextExtra();
      });
      extraPrompt.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-index]");
        if (button) answerExtraStress(Number(button.dataset.index));
      });
      extraOptions.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-correct]");
        if (button) answerExtraForm(button);
      });
      extraMarkHardButton.addEventListener("click", () => {
        markExtraHard("manual");
        updateExtraHardStatus();
      });
      extraRemoveHardButton.addEventListener("click", removeExtraHard);
      extraNextButton.addEventListener("click", nextExtra);
      window.addEventListener("resize", resizeCanvas);

      applyTheme(window.localStorage.getItem(THEME_KEY) === "dark" ? "dark" : "light");
      showHome();
      updateTrainingUI();
      resizeCanvas();
      checkBackend();
      loadWords();
    })();
  </script>
</body>
