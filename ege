      align-content: center;
      justify-items: center;
      text-align: center;
    }

    .quiz-kind {
      color: var(--muted);
      font-size: 13px;
      font-weight: 850;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .quiz-prompt {
      margin: 0;
      max-width: 900px;
      font-size: clamp(30px, 5vw, 64px);
      line-height: 1.05;
      font-weight: 900;
      letter-spacing: 0;
      overflow-wrap: anywhere;
      user-select: text;
    }

    .stress-word {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2px;
      max-width: 100%;
    }

    .stress-letter {
      min-width: 0.64em;
      min-height: 1.12em;
      display: inline-grid;
      place-items: center;
      border: 1px solid transparent;
      border-radius: 8px;
      background: transparent;
      color: var(--ink);
      font: inherit;
      padding: 0 3px;
    }

    button.stress-letter {
      cursor: pointer;
    }

    button.stress-letter:hover,
    .stress-letter.selected {
      border-color: var(--blue);
      background: var(--blue-soft);
      color: var(--blue);
    }

    .stress-letter.correct {
      border-color: rgba(19, 121, 91, 0.45);
      background: rgba(19, 121, 91, 0.12);
      color: var(--green);
    }

    .stress-letter.wrong {
      border-color: rgba(180, 35, 24, 0.45);
      background: rgba(180, 35, 24, 0.12);
      color: var(--red);
    }

    .option-grid {
      width: min(760px, 100%);
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .option-grid button {
      min-height: 78px;
      padding: 14px;
      font-size: clamp(20px, 3vw, 34px);
      font-weight: 850;
      line-height: 1.12;
      overflow-wrap: anywhere;
    }

    .option-grid button.correct {
      border-color: rgba(19, 121, 91, 0.5);
      background: rgba(19, 121, 91, 0.12);
      color: var(--green);
    }

    .option-grid button.wrong {
      border-color: rgba(180, 35, 24, 0.5);
      background: rgba(180, 35, 24, 0.12);
      color: var(--red);
    }

    .extra-feedback {
      min-height: 28px;
      margin: 0;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.4;
      font-weight: 800;
    }

    .extra-feedback.good {
      color: var(--green);
    }

    .extra-feedback.bad {
      color: var(--red);
    }

    @media (max-width: 760px) {
      body {
        padding: 14px;
      }

      main {
        grid-template-columns: 1fr;
      }

      .exercise-grid {
        grid-template-columns: 1fr;
      }

      .word {
        font-size: clamp(34px, 12vw, 54px);
        min-height: 58px;
      }

      .task-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .home-hero,
      .menu-grid,
      .trainer-layout,
      .option-grid {
        grid-template-columns: 1fr;
      }

      .home-title {
        font-size: clamp(34px, 12vw, 48px);
      }

      .menu-card {
        min-height: 0;
      }

      .hero-panel {
        min-height: 240px;
      }

      .pad-shell,
      .toolbar {
        width: min(100%, 260px);
      }
    }
  </style>
</head>
